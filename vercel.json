{
  "version": 2,
  "builds": [
    {
      "src": "*.js",
      "use": "@vercel/node"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://personal-library-client.vercel.app"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, PUT, POST, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Authorization, Accept, Keep-Alive, Content-Encoding, Cache-Control, Cookie, Content-Type, Content-Length, Content-Language"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        }
      ]
    }
  ]
}